# Arch Helper — environment settings
#
# Install.cmd copies this file to .env on first install (if .env does not exist).
# Edit .env only when something differs from the defaults below.
#
# Required checks after install:
#   - EMULATOR_DIR points to your MuMu or LDPlayer install folder
#   - ADB_PORT matches your emulator instance (MuMu: 16384 + index * 32)
#   - GAME_PACKAGE matches Archero 2 on your device

# --- Emulator (MuMu Player 12 — default) ---
EMULATOR=mumu
EMULATOR_DIR=D:\Program Files\Netease\MuMuPlayer\nx_main
EMULATOR_INDEX=0
ADB_HOST=127.0.0.1
ADB_PORT=16384

# --- LDPlayer 9 (uncomment and comment MuMu block above) ---
# EMULATOR=ldplayer
# EMULATOR_DIR=D:\LDPlayer\LDPlayer9
# EMULATOR_INDEX=0
# ADB_HOST=127.0.0.1
# ADB_PORT=5555

# --- Game ---
GAME_PACKAGE=com.xq.archeroii

# --- Optional: presets + run state folder (default: ./data next to the bot) ---
# ARCHERO_DATA_DIR=D:\ArchHelper\data
